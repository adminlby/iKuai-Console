# ===== Backend (server) =====
# iKuai device (used to read the WAN gateway for ISP-latency pings).
IKUAI_BASE=https://192.168.1.1
IKUAI_TOKEN=your-api-token-here

# Role: all (default) | probe | web. Leave UNSET here — docker-compose sets it
# per service (probe on host net, web on 1panel-network). Single-process runs
# (npm) just use the default 'all'.
# ROLE=all

# HTTP port the backend listens on (frontend proxies /svc here).
SVC_PORT=5274
# Probe interval in ms (default 60s).
PROBE_INTERVAL_MS=60000
# Geo-IP lookup used to resolve the current ISP name from the WAN IP.
ISP_LOOKUP_URL=http://ip-api.com/json/?fields=status,isp,org,as,query,city,country&lang=zh-CN

# ===== MySQL =====
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=ikuai_console
