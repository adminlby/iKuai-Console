            "minLength": 1,
            "maxLength": 15,
            "pattern": "^[\\\\u4e00-\\\\u9fa5a-zA-Z0-9][\\\\u4e00-\\\\u9fa5a-zA-Z0-9_-]*$",
            "example": "33"
          },
          "comment": {
            "type": "string",
            "description": "备注信息，最多64个字符，不支持特殊字符",
            "maxLength": 64,
            "example": ""
          },
