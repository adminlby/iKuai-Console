          },
          "name": {
            "type": "string",
            "description": "共享名（唯一，不可为空）",
            "example": "share1"
          },
          "perm": {
            "type": "string",
            "description": "用户权限（rw读写，ro只读）",
            "enum": [
              "rw",
              "ro"
            ],
            "example": "rw"
          },
          "guest": {
            "type": "string",
            "description": "访客是否可以访问",
