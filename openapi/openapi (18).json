                        "total": 218429238
                      },
                      {
                        "id": 2149034,
                        "timestamp": 1773217200,
                        "appid": 2580003,
                        "appname": "微信",
                        "conn_cnt": 5,
                        "upload": 0,
                        "download": 0,
                        "total_up": 2290568,
                        "total_down": 209349430,
                        "total": 211639998
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
