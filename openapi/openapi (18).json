          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/api/v4.0/monitoring/app-protocols/terminal-load": {
      "get": {
        "summary": "获取访问指定应用协议的终端列表",
        "description": "查询有哪些终端访问过指定的应用协议，列出终端当前的上下行速率、\n总流量、连接数、主机名、MAC地址等信息。\n必须指定应用协议ID（appid）。\n不支持limit、page、key、pattern、filter。\n",
        "operationId": "getAppProtocolTerminalLoad",
        "tags": [
          "monitor-app-traffic"
        ],
        "parameters": [
          {
            "name": "appid",
            "in": "query",
            "required": true,
            "description": "应用协议ID，必须指定",
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 2580003
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取访问指定应用协议的终端列表",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/AppProtocolTerminalLoadResponse"
                },
                "example": {
