                        "icmp_connect_num": 2,
                        "upload": 0,
                        "download": 0,
                        "total_up": 22867423,
                        "total_down": 180169006
                      },
                      "uptime": 9837,
                      "verinfo": {
                        "modelname": "",
                        "verstring": "4.0.111-beta x64 Enterprise Build202603131338",
                        "version": "4.0.111",
