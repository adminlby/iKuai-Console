        "tags": [
          "monitor-load"
        ],
        "responses": {
          "200": {
            "description": "成功获取系统实时状态",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SystemInfoResponse"
                },
                "example": {
                  "message": "Success",
                  "results": {
                    "sysinfo": {
