    "/api/v4.0/monitoring/cpu": {
      "get": {
        "summary": "获取CPU负载监控数据",
        "description": "获取指定时间范围内的CPU负载监控数据。\n支持按小时、天、周、月进行数据聚合，可选择平均值或最大值。\n",
        "operationId": "getCpuLoad",
        "tags": [
          "monitor-load"
        ],
        "parameters": [
          {
            "name": "datetype",
            "in": "query",
            "description": "数据聚合类型",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "hour",
                "day",
                "week",
                "month"
              ],
              "example": "hour"
            }
          },
          {
            "name": "start_time",
            "in": "query",
            "description": "开始时间戳",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1763532000
            }
          },
          {
            "name": "end_time",
            "in": "query",
            "description": "结束时间戳",
            "required": true,
            "schema": {
              "type": "integer",
              "format": "int64",
              "example": 1763536500
            }
          },
          {
            "name": "math",
            "in": "query",
            "description": "数学计算方式",
            "required": true,
            "schema": {
              "type": "string",
              "enum": [
                "avg",
                "max"
              ],
              "example": "avg"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "成功获取CPU负载数据",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CpuLoadResponse"
                },
                "example": {
                  "message": "Success",
                  "results": {
                    "cpu": [
                      {
                        "cpu": 0,
                        "timestamp": 1763532960
                      }
                    ]
                  }
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          },
          "403": {
            "$ref": "#/components/responses/Forbidden"
          },
          "500": {
            "$ref": "#/components/responses/InternalServerError"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
