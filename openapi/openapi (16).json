          "application/json": {
            "schema": {
              "allOf": [
                {
                  "$ref": "#/components/schemas/ErrorResponse"
                },
                {
                  "example": {
                    "message": "请求参数错误"
                  }
                }
              ]
            }
          }
        }
      },
      "Unauthorized": {
        "description": "未认证或凭证无效",
