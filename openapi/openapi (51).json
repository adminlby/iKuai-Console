            "example": "key1"
          },
          "type": {
            "type": "string",
            "description": "校验类型，由业务返回",
            "example": "unique"
          },
          "msg": {
            "type": "string",
            "description": "具体错误说明，由业务返回",
            "example": "详细的错误输出"
          }
        },
        "additionalProperties": false
      }
